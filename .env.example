# DATABASE_URL: PostgreSQL connection string for Prisma.
# The app uses PostgreSQL instead of JSON file storage.
DATABASE_URL="postgresql://pr_user:pr_password@localhost:5432/pr_survey_db"

# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where the app is hosted.
# Used for self-referential links and API endpoints.
APP_URL="http://localhost:3000"

# EVOLUTION_API_URL: The URL of your Evolution API WhatsApp gateway.
# Required for sending actual WhatsApp messages automatically.
# Leave as default to use placeholder (no real messages sent).
EVOLUTION_API_URL="https://api.evolution.example.com/message/sendText"

# EVOLUTION_API_KEY: Your Evolution API authentication key.
EVOLUTION_API_KEY="dummy_api_key"

# JWT_SECRET: Secret key for signing JWT tokens.
# Change this to a secure random string in production.
JWT_SECRET="super-secret-change-in-production"
